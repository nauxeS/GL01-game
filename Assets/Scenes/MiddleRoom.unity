PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 0}
    m_Modifications:
    - target: {fileID: 284976603973504393, guid: 018a0afb1d3b674459f7098ba72df3cb, type: 3}
      propertyPath: m_Name
      value: GameNote
      objectReference: {fileID: 0}
    - target: {fileID: 1488577052005094986, guid: 018a0afb1d3b674459f7098ba72df3cb, type: 3}
      propertyPath: _data._json
      value: '{"declarations":{"Kind":"Object","collection":{"$content":[{"name":"Titre","value":{"$content":"Lettre
        du 12/10/1431","$type":"System.String"},"typeHandle":{"Identification":"System.String,
        mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","$version":"A"},"$version":"A"},{"name":"Contenu","value":{"$content":["Bonjour,
        je m''appelle Gireli. Je viens finalement d''arriver au ch\u00e2teau de Balderia
        apr\u00e8s des heures pass\u00e9es \u00e0 affronter des monstres dans la
        for\u00eat.","En tant qu''aventurier chevronn\u00e9, je suis bien d\u00e9terminer
        \u00e0 rencontrer le p\u00e8re Religi.","Dans ce monde bien fade, souill\u00e9
        par la maladie et la peste, il repr\u00e9sente une lueur d''espoir, capable
        de r\u00e9aliser votre souhait le plus cher... Et le plus \u00e9go\u00efste.","Je
        compte bien explorer ce ch\u00e2teau de fond en comble. Je suis persuad\u00e9
        qu''il se cache derri\u00e8re cette grande porte en bois."],"$type":"System.Collections.Generic.List`1[[System.String,
        mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089]]"},"typeHandle":{"Identification":"System.Collections.Generic.List`1[[System.String,
        mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089]],
        mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","$version":"A"},"$version":"A"}],"$version":"A"},"$version":"A"}}'
      objectReference: {fileID: 0}
