    - target: {fileID: 1488577052005094986, guid: 018a0afb1d3b674459f7098ba72df3cb, type: 3}
      propertyPath: _data._json
      value: '{"declarations":{"Kind":"Object","collection":{"$content":[{"name":"Titre","value":{"$content":"Lettre
        du 14/10/1431","$type":"System.String"},"typeHandle":{"Identification":"System.String,
        mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","$version":"A"},"$version":"A"},{"name":"Contenu","value":{"$content":["Cela
        fait maintenant quelques jours que je suis arriv\u00e9 dans ce manoir...
        C''est \u00e0 n''y rien comprendre, ces leviers semblent faire dispara\u00eetre
        ces obstacles comme par magie...","Mais surtout ce lieu est infest\u00e9
        de monstres ! Si \u00e7a se trouve, p\u00e8re Religi est d\u00e9j\u00e0...
        Non, je ne peux pas le croire ! Il est forc\u00e9ment quelque part.","C''est
        peut-\u00eatre une forme d''\u00e9preuve pour tester notre valeur... Dans
        ce cas je rel\u00e8ve le d\u00e9fi !"],"$type":"System.Collections.Generic.List`1[[System.String,
        mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089]]"},"typeHandle":{"Identification":"System.Collections.Generic.List`1[[System.String,
