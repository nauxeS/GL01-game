  m_Script: {fileID: 11500000, guid: e741851cba3ad425c91ecf922cc6b379, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  _data:
    _json: '{"declarations":{"Kind":"Object","collection":{"$content":[{"name":"FirstDialogue","value":{"$content":["Oh,
      bonjour mon enfant...","Je m''appelle Gireli. Enfin, si mes souvenirs sont
      bons.","\u00c0 vrai dire, je ne me rappelle m\u00eame plus \u00eatre entr\u00e9
      dans ce ch\u00e2teau...","Ni m\u00eame pourquoi je suis venu ici...","Cependant,
      je serai peut-\u00eatre capable de t''aider...","N''h\u00e9site pas \u00e0
      revenir me parler si l''envie t''en prend."],"$type":"System.Collections.Generic.List`1[[System.String,
      mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089]]"},"typeHandle":{"Identification":"System.Collections.Generic.List`1[[System.String,
      mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089]],
      mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","$version":"A"},"$version":"A"},{"name":"Indices","value":{"$content":["Il
      y a un \u00e9tage avec une biblioth\u00e8que gigantesque... ","On peut y trouver
      toutes sortes de livres.","Tu as vu cette \u00e9tag\u00e8re en bouleau ?","Elle
      a toujours attir\u00e9 mon attention...","Il y a cimeti\u00e8re avec des statues
      magnifiques dehors... ","Je te conseille d''aller les contempler, elles apaisent
      mon coeur..."],"$type":"System.Collections.Generic.List`1[[System.String, mscorlib,
      Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089]]"},"typeHandle":{"Identification":"System.Collections.Generic.List`1[[System.String,
      mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089]],
      mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089","$version":"A"},"$version":"A"}],"$version":"A"},"$version":"A"}}'
    _objectReferences: []
